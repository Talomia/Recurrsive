{
  "services": [
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "postgres",
        "source": {
          "type": "image",
          "image": "apache/age:release_PG16_1.5.0"
        },
        "env": "POSTGRES_PASSWORD=recurrsive",
        "deploy": {
          "command": null,
          "replicas": 1,
          "zeroDowntime": true
        },
        "mounts": [
          {
            "type": "volume",
            "name": "pgdata",
            "mountPath": "/var/lib/postgresql/data"
          }
        ]
      }
    },
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "server",
        "source": {
          "type": "github",
          "autoDeploy": false,
          "owner": "Talomia",
          "repo": "Recurrsive",
          "ref": "main",
          "path": "/"
        },
        "build": {
          "type": "dockerfile",
          "file": "docker/Dockerfile"
        },
        "env": "DATABASE_URL=postgresql://postgres:recurrsive@recurrsive_postgres:5432/postgres\nGRAPH_PROVIDER=postgresql_age\nPORT=3000\nHOST=0.0.0.0\nNODE_ENV=production\nJWT_SECRET=change-me-in-production\nCORS_ORIGIN=https://recurrsive-dashboard.easypanel.host\nALLOW_DEMO_USERS=false\nENABLE_ENTERPRISE=true\nENABLE_ECOSYSTEM=true\nRECURRSIVE_LLM_PROVIDER=openai\nRECURRSIVE_LLM_MODEL=gpt-4.1-mini\nRECURRSIVE_LLM_API_KEY=\nRECURRSIVE_WEBHOOK_SECRET=\nRECURRSIVE_WEBHOOK_TIMEOUT_MS=5000\nRECURRSIVE_WEBHOOK_MAX_RETRIES=3",
        "deploy": {
          "command": null,
          "replicas": 1,
          "zeroDowntime": true
        },
        "domains": [
          {
            "host": "recurrsive-server.easypanel.host",
            "port": 3000,
            "https": true,
            "path": "/",
            "internalProtocol": "http",
            "wildcard": false,
            "certificateResolver": "",
            "middlewares": []
          }
        ]
      }
    },
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "dashboard",
        "source": {
          "type": "github",
          "autoDeploy": false,
          "owner": "Talomia",
          "repo": "Recurrsive",
          "ref": "main",
          "path": "/"
        },
        "build": {
          "type": "dockerfile",
          "file": "docker/Dockerfile.dashboard"
        },
        "env": "NEXT_PUBLIC_API_URL=https://recurrsive-server.easypanel.host\nPORT=3100\nNODE_ENV=production",
        "deploy": {
          "command": null,
          "replicas": 1,
          "zeroDowntime": true
        },
        "domains": [
          {
            "host": "recurrsive-dashboard.easypanel.host",
            "port": 3100,
            "https": true,
            "path": "/",
            "internalProtocol": "http",
            "wildcard": false,
            "certificateResolver": "",
            "middlewares": []
          }
        ]
      }
    },
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "website",
        "source": {
          "type": "github",
          "autoDeploy": false,
          "owner": "Talomia",
          "repo": "Recurrsive",
          "ref": "main",
          "path": "/"
        },
        "build": {
          "type": "dockerfile",
          "file": "docker/Dockerfile.website"
        },
        "env": "PORT=3200\nNODE_ENV=production",
        "deploy": {
          "command": null,
          "replicas": 1,
          "zeroDowntime": true
        },
        "domains": [
          {
            "host": "recurrsive-website.easypanel.host",
            "port": 3200,
            "https": true,
            "path": "/",
            "internalProtocol": "http",
            "wildcard": false,
            "certificateResolver": "",
            "middlewares": []
          }
        ]
      }
    }
  ]
}
