{
  "services": [
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "postgres",
        "source": {
          "type": "image",
          "image": "apache/age:PG16-v1.5.0-rc1"
        },
        "deploy": {},
        "env": "POSTGRES_PASSWORD=recurrsive",
        "mounts": [
          {
            "type": "volume",
            "name": "pgdata",
            "mountPath": "/var/lib/postgresql"
          }
        ]
      }
    },
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "server",
        "source": {
          "type": "image",
          "image": "ghcr.io/talomia/recurrsive-server:latest"
        },
        "deploy": {},
        "env": "DATABASE_URL=postgresql://postgres:recurrsive@$(PROJECT_NAME)_postgres:5432/postgres\nGRAPH_PROVIDER=postgresql_age\nPORT=3000\nNODE_ENV=production\nRECURRSIVE_LLM_PROVIDER=openai\nRECURRSIVE_LLM_MODEL=gpt-4.1-mini\nRECURRSIVE_LLM_API_KEY=\nRECURRSIVE_WEBHOOK_SECRET=\nRECURRSIVE_WEBHOOK_TIMEOUT_MS=5000\nRECURRSIVE_WEBHOOK_MAX_RETRIES=3",
        "domains": [
          {
            "host": "$(EASYPANEL_DOMAIN)",
            "port": 3000
          }
        ]
      }
    },
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "dashboard",
        "source": {
          "type": "image",
          "image": "ghcr.io/talomia/recurrsive-dashboard:latest"
        },
        "deploy": {},
        "env": "NEXT_PUBLIC_API_URL=http://$(PROJECT_NAME)_server:3000\nPORT=3100\nNODE_ENV=production",
        "domains": [
          {
            "host": "$(EASYPANEL_DOMAIN)",
            "port": 3100
          }
        ]
      }
    },
    {
      "type": "app",
      "data": {
        "projectName": "recurrsive",
        "serviceName": "website",
        "source": {
          "type": "image",
          "image": "ghcr.io/talomia/recurrsive-website:latest"
        },
        "deploy": {},
        "env": "PORT=3200\nNODE_ENV=production",
        "domains": [
          {
            "host": "$(EASYPANEL_DOMAIN)",
            "port": 3200
          }
        ]
      }
    }
  ]
}
