# ─────────────────────────────────────────────────────────────────────────────
# Recurrsive — Environment Configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Connection URL for PostgreSQL with Apache AGE extension.
# For local development with SQLite, leave this unset.
# DATABASE_URL=postgresql://recurrsive:recurrsive@localhost:5432/recurrsive

# Graph storage backend: "sqlite" (default, zero-config) or "age" (PostgreSQL).
# GRAPH_PROVIDER=sqlite

# ── API Server ───────────────────────────────────────────────────────────────
# URL of the Recurrsive API server (used by the dashboard for API proxy).
# Default: http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3000

# Alternative API URL used by CLI and packages.
# Default: http://localhost:3000
# RECURRSIVE_API_URL=http://localhost:3000

# Allowed CORS origins (comma-separated). Defaults to allow all in dev.
# ⚠️  Set in production to restrict cross-origin API access.
# CORS_ORIGIN=https://your-dashboard.example.com

# ── LLM Providers (Optional) ────────────────────────────────────────────────
# Required only for AI-powered analysis features (reasoning, intelligence).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── API Authentication ───────────────────────────────────────────────────────
# JWT secret for signing authentication tokens.
# ⚠️  REQUIRED in production! Generate with: openssl rand -hex 32
# The server EXITS on startup in production if this is unset or left at an
# insecure placeholder (e.g. "REPLACE_WITH_STRONG_SECRET"). Dev falls back to
# an insecure default with a warning.
# JWT_SECRET=your-strong-random-secret-here

# API key for server authentication. Auto-generated if not set.
# API_KEY=your-api-key-here

# ── First-run bootstrap ────────────────────────────────────────────────────────
# There are NO demo/built-in users. On a fresh install (zero users), create the
# first admin account with:
#   curl -X POST http://<host>/api/v1/setup \
#     -H 'Content-Type: application/json' \
#     -d '{"username":"admin","email":"you@example.com","password":"<min 8 chars>"}'
# The response returns a JWT (auto-login). After the first user exists, /setup
# returns 409. Add further users via admin-issued invites (/api/v1/invites).

# ── SQLite Data Store ────────────────────────────────────────────────────────
# Path to the SQLite database for server state persistence.
# Default: ./data/recurrsive.db (relative to the server working directory)
# DATABASE_PATH=./data/recurrsive.db

# ── Unified LLM API Key ─────────────────────────────────────────────────────
# Single key for reasoning engine (auto-detects provider from key prefix).
# Alternatively, set OPENAI_API_KEY or ANTHROPIC_API_KEY above.
# RECURRSIVE_LLM_API_KEY=sk-...

# ── Collector Credentials (Optional) ────────────────────────────────────────
# These enable external data collection. All collectors work gracefully without
# credentials — they simply return empty results and log a warning.

# GitHub Collector — PRs, workflows, deployments, contributors
# GITHUB_TOKEN=ghp_...

# GitLab Collector — MRs, pipelines, deployments, members
# GITLAB_TOKEN=glpat-...
# GITLAB_URL=https://gitlab.com

# Sentry Error Tracking Collector
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# Datadog APM Collector
# DATADOG_API_KEY=...
# DATADOG_APP_KEY=...

# New Relic APM Collector (alternative to Datadog)
# NEWRELIC_API_KEY=NRAK-...

# Grafana APM Collector (alternative to Datadog/New Relic)
# GRAFANA_API_KEY=glsa_...
# GRAFANA_URL=https://your-instance.grafana.net

# Langfuse LLM Observability Collector
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_URL=https://cloud.langfuse.com

# Arize ML Monitoring Collector
# ARIZE_API_KEY=...
# ARIZE_SPACE_KEY=...

# Helicone LLM Cost Tracking Collector
# HELICONE_API_KEY=sk-helicone-...

# Cloud Cost Collector (AWS)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# CLOUD_COST_CSV_PATH=./costs.csv  # Alternative: import from CSV file

# ── Notifications ────────────────────────────────────────────────────────────
# Slack webhook URL for Slack notification channel.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Webhook Delivery ─────────────────────────────────────────────────────────
# Timeout for webhook HTTP delivery attempts (milliseconds).
# Default: 5000
# RECURRSIVE_WEBHOOK_TIMEOUT_MS=5000
