# ─────────────────────────────────────────────────────────────────────────────
# Recurrsive — Environment Variables
#
# Copy this file to `.env` and fill in the values:
#   cp docker/.env.example docker/.env
#
# Docker Compose will automatically load docker/.env when run from the
# docker/ directory, or you can specify it explicitly:
#   docker compose --env-file docker/.env -f docker/docker-compose.yml up
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by the server container)
DATABASE_URL=postgresql://recurrsive:recurrsive@postgres:5432/recurrsive

# Graph provider: 'postgresql_age' (production) or 'sqlite' (embedded)
GRAPH_PROVIDER=postgresql_age

# ── Server ────────────────────────────────────────────────────────────────────
# Port the API server listens on
PORT=3000

# Node.js environment
NODE_ENV=production

# ── Authentication ────────────────────────────────────────────────────────────
# HMAC-SHA256 secret for JWT signing (REQUIRED in production!)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# ── SQLite Data Store ─────────────────────────────────────────────────────────
# Path to the SQLite database for server state persistence
# Default: ./data/recurrsive.db (relative to the server working directory)
# DATABASE_PATH=./data/recurrsive.db

# ── LLM / Reasoning Engine ───────────────────────────────────────────────────
# Provider: 'openai', 'anthropic', etc.
RECURRSIVE_LLM_PROVIDER=openai

# Model identifier
RECURRSIVE_LLM_MODEL=gpt-4.1-mini

# API key for the LLM provider (required for reasoning engine)
RECURRSIVE_LLM_API_KEY=

# Custom base URL for the LLM API (optional, for proxies or self-hosted)
# RECURRSIVE_LLM_BASE_URL=

# ── PostgreSQL (container-level, used by the postgres service) ────────────────
POSTGRES_USER=recurrsive
POSTGRES_PASSWORD=recurrsive
POSTGRES_DB=recurrsive

# ── Collector Credentials (Optional) ────────────────────────────────────────
# All collectors work gracefully without credentials — empty results + warning.

# GitHub Collector
# GITHUB_TOKEN=ghp_...

# GitLab Collector
# GITLAB_TOKEN=glpat-...
# GITLAB_URL=https://gitlab.com

# Sentry Error Tracking
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# Datadog APM
# DATADOG_API_KEY=...
# DATADOG_APP_KEY=...

# Langfuse LLM Observability
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_URL=https://cloud.langfuse.com

# Arize ML Monitoring
# ARIZE_API_KEY=...
# ARIZE_SPACE_KEY=...

# Helicone LLM Cost Tracking
# HELICONE_API_KEY=sk-helicone-...

# ── Notifications ────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
