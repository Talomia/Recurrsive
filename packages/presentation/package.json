{
  "name": "@recurrsive/presentation",
  "version": "0.5.7",
  "private": true,
  "description": "Report generation, notifications, and terminal formatting for the Recurrsive engineering intelligence platform",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Talomia/Recurrsive.git",
    "directory": "packages/presentation"
  },
  "type": "module",
  "main": "./dist/index.js",
