{
  "name": "@recurrsive/collectors",
  "version": "0.5.7",
  "private": true,
  "description": "Data collectors for the Recurrsive knowledge graph",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Talomia/Recurrsive.git",
    "directory": "packages/collectors"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@recurrsive/core": "workspace:*",
    "chokidar": "^4.0.0",
    "glob": "^11.0.0",
    "ignore": "^6.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
