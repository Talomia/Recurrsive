{
  "name": "@recurrsive/graph",
  "version": "0.5.7",
  "private": true,
  "description": "Knowledge Graph engine for Recurrsive - Digital Twin storage layer",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Talomia/Recurrsive.git",
    "directory": "packages/graph"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@recurrsive/core": "workspace:*",
    "pg": "^8.13.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
