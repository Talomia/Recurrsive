    "@recurrsive/parsers": "workspace:*",
    "@recurrsive/policy": "workspace:*",
    "@recurrsive/presentation": "workspace:*",
    "@recurrsive/reasoning": "workspace:*",
    "@types/pg": "^8.11.0",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.0.0",
    "pg": "^8.13.0"
